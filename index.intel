<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8" />
    <title>Punchers</title>
    <style>
      html, body {
        margin: 0;
        padding: 0;
        height: 100%;
        background: #000;
        overflow: hidden;
      }
      #game-frame {
        border: none;
        width: 100%;
        height: 100%;
      }
    </style>
  </head>
  <body>
    <!-- Replace the src below with a working Punchers WebGL URL -->
    <iframe
      id="game-frame"
      src="https://example.com/punchers/index.html"
      allowfullscreen
    ></iframe>
  </body>
</html>
